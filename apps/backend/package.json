    "prettier": "^3.8.3",
    "tsx": "^4.22.4"
  },
  "dependencies": {
    "@clerk/express": "^2.1.23",
    "@neondatabase/serverless": "^1.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "axios": "^1.17.0",
    "bullmq": "^5.78.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.1",
    "express": "^5.2.1",
